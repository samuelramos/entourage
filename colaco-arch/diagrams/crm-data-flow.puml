@startuml crm-data-flow
title CRM Data Flow

skinparam componentStyle rectangle

package "Azure" {
  database "PostgreSQL\n(CRM Contacts)" as pg
}

component "Debezium\n(Kafka Connect)" as debezium

package "Confluent" {
  queue "Kafka Topics\n(CRM CDC events)" as kafka
}

component "Downstream Consumers\n(TBC)" as consumers

pg -right-> debezium : WAL / CDC
debezium -right-> kafka : change events\n(real-time)
kafka -right-> consumers

@enduml
